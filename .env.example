# Copy to `.env` and fill in. Read by docker-compose for the inference service.

# --- LLM (agent reasoning) -------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
ANTHROPIC_MODEL=anthropic/claude-opus-4-7
OPENROUTER_REFERER=http://localhost:3000
OPENROUTER_TITLE=Trajecta

# --- Embeddings (RAG) ------------------------------------------------------
OPENAI_API_KEY=sk-REPLACE_ME
EMBEDDING_MODEL=text-embedding-3-small

# --- HuggingFace (Llama-3.2-1B is gated) -----------------------------------
HUGGING_FACE_HUB_TOKEN=hf_REPLACE_ME
BASE_LLM_ID=meta-llama/Llama-3.2-1B
LORA_R=32
LAMBDA_REG=0.5

# --- RAG corpus version stamp ---------------------------------------------
RAG_CORPUS_VERSION=v1-2026-05-22

# --- Inference backend ----------------------------------------------------
# 'local'      → load checkpoints in-process (needs GPU + OpenTSLM + ckpt mount)
# 'sagemaker'  → boto3.invoke_endpoint() against the SM endpoint built via
#                sagemaker-deploy/. See sagemaker-deploy/README.md.
# 'tunnel'     → proxy /predict and /ids to a remote FastAPI behind a
#                cloudflared tunnel. The remote owns the checkpoint; this
#                service only relays + does judging.
INFERENCE_BACKEND=local

# Only used when INFERENCE_BACKEND=tunnel:
TUNNEL_URL=https://your-tunnel.trycloudflare.com
TUNNEL_TAU_HIGH=1.5

# Only used when INFERENCE_BACKEND=sagemaker:
SAGEMAKER_ENDPOINT_NAME=trajecta-tslm
SAGEMAKER_REGION=us-west-2
SAGEMAKER_VARIANTS=v1a,v1b
SAGEMAKER_PARALLEL=4
SAGEMAKER_ASYNC=0
# Either provide explicit creds OR rely on an EC2/IRSA instance role.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# --- CORS -----------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# --- Spend control --------------------------------------------------------
OPENROUTER_DAILY_USD_CAP=20
EVAL_AGENT_PER_IP_HOURLY=10
PREDICT_PER_IP_HOURLY=120
DEMO_TOKEN=
