# Trajecta frontend env

# VITE_API_BASE_URL: where the bundle should send /api requests at runtime.
# Defaults to "/api" (same-origin proxy via nginx in prod, Vite proxy in dev).
# Override for a separately-hosted inference service:
#   VITE_API_BASE_URL=https://api.trajecta.dev
VITE_API_BASE_URL=/api

# DEV_API_URL: target for the Vite dev proxy (`/api → DEV_API_URL`).
# Only read by vite.config.ts during `npm run dev`.
DEV_API_URL=http://localhost:8000
