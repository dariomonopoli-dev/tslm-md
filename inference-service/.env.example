# --- LLM (agent reasoning) -------------------------------------------------
# OpenRouter routes to Claude. OpenAI key is for embeddings only, never LLM.
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
ANTHROPIC_MODEL=anthropic/claude-opus-4-7
OPENROUTER_REFERER=http://localhost:3000
OPENROUTER_TITLE=Trajecta

# --- Embeddings (RAG) -------------------------------------------------------
OPENAI_API_KEY=sk-REPLACE_ME
EMBEDDING_MODEL=text-embedding-3-small

# --- RAG store --------------------------------------------------------------
CHROMA_PATH=/app/data/chroma
RAG_CORPUS_VERSION=v1-2026-05-22

# --- Inference --------------------------------------------------------------
CHECKPOINT_DIR=/app/checkpoints
MISATO_HDF5_PATH=/app/data/MD.hdf5
TEST_SPLIT_PATH=/app/data/test_MD.txt

# --- Web --------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000
DEMO_TOKEN=

# --- Spend control ----------------------------------------------------------
OPENROUTER_DAILY_USD_CAP=20
EVAL_AGENT_PER_IP_HOURLY=10
