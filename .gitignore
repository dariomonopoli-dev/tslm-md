# baselines.json — training-run scratch output
baselines.json

# preprocessed/ + preprocessed_v2/ are now committed (~130 MB total) so the
# SageMaker deploy bundle can pull them from the repo. MD.hdf5 (124 GB) is
# still gitignored below — the npz/jsonl files in preprocessed/ are the
# distilled inputs the model actually trained on.

# Source datasets (too large, downloaded separately)
MD.hdf5
*.hdf5
*.h5
QM*.hdf5

# Reference repos (clone separately if needed for re-preprocessing)
misato-affinity/
misato-dataset-master/

# Heavy artefacts (never commit)
data/*
!data/targets.json
!data/feature_stats.json
!data/s3_data_loader.py
!data/splits/*
!data/featurized.h5
!data/.gitkeep
third_party/*
!third_party/.gitkeep
checkpoints/
results/
*.pt
*.bin
*.safetensors

# Python env
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
*.egg-info/
build/
dist/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# OpenTSLM + trajecta came with their own inner .git directories; we keep
# them as plain files in this repo and stash the original .git as .git.bak/
# so the upstream history is recoverable without polluting our history.
OpenTSLM/.git.bak/
trajecta/.git.bak/

# Separate frontend project (its own repo, not part of training pipeline)
website/

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# HF / model caches
.cache/

# Streamlit
.streamlit/secrets.toml

# Local env
.env
.env.local

# Local run outputs
runs/
*.log
